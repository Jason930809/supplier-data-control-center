  "rules": [
    {
      "id": "attr-style",
      "priority": 1000,
      "patterns": [
        "^(modern|traditional|bohemian|coastal|scandinavian|transitional modern|country farmhouse|mid century modern|tropical|rustic lodge|glam|shag flokati)$"
      ],
      "decision": "blocked",
      "suggested": "Product type required",
      "redirectField": "style",
      "reason": "该值只描述风格，不能直接写入商品品类。"
    },
    {
      "id": "attr-lifecycle",
      "priority": 990,
      "patterns": [
        "^(closeout|clearance|discontinued|new arrivals?|sale)$"
      ],
      "decision": "blocked",
      "suggested": "Product type required",
      "redirectField": "lifecycleStatus",
      "reason": "该值是销售状态，不是商品类型。"
    },
    {
      "id": "attr-shape",
      "priority": 980,
      "patterns": [
        "^(l shape|u shape|curved|round|square|rectangle|rectangular|oval)$"
      ],
      "decision": "blocked",
      "suggested": "Product type required",
      "redirectField": "shape",
      "reason": "该值只描述形状，必须从标题或详情继续识别商品类型。"
    },
    {
      "id": "attr-room",
      "priority": 970,
      "patterns": [
        "^(living room|bedroom|dining room|office|outdoor room)$"
      ],
      "decision": "blocked",
      "suggested": "Product type required",
      "redirectField": "room",
      "reason": "该值只描述使用空间，不能替代商品类型。"
    },
    {
      "id": "attr-assortment",
      "priority": 960,
      "patterns": [
        "^(collection|collections|allstate living items|new products?|featured|assortment)$"
      ],
      "decision": "blocked",
      "suggested": "Product type required",
      "redirectField": "assortment",
      "reason": "该值是系列或营销分组，必须回到商品本身识别类型。"
    },
    {
      "id": "bed-size-only",
      "priority": 950,
      "patterns": [
        "^(king|queen|cal king|california king|eastern king|twin|full|ck|ek)$"
      ],
      "decision": "review",
      "targetId": "bed",
      "suggested": "Bed",
      "redirectField": "bedSize",
      "reason": "可以判断是床，但尺寸必须移到 bedSize；自动写入前需确认没有床垫或床品混入。"
    },
